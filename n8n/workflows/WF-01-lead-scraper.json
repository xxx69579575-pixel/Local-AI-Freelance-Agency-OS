{
  "meta": {
    "instanceId": "local"
  },
  "name": "WF-01 Lead Scraper",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 * * * *"
            }
          ]
        },
        "timezone": "Asia/Taipei"
      },
      "id": "node-wf01-01",
      "name": "Schedule - Every Hour",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        240,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "// Emit one item per scraping source\nreturn [\n  { json: { source: 'pro360' } },\n  { json: { source: 'tasker' } }\n];"
      },
      "id": "node-wf01-02",
      "name": "Set Sources",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        464,
        304
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://scraper:3001/scrape",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "source",
              "value": "={{ $json.source }}"
            },
            {
              "name": "limit",
              "value": "20"
            },
            {
              "name": "delay_min_ms",
              "value": "3000"
            },
            {
              "name": "delay_max_ms",
              "value": "6000"
            }
          ]
        },
        "options": {
          "timeout": 600000
        }
      },
      "id": "node-wf01-03",
      "name": "HTTP - Scrape Source",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        688,
        304
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "loose"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "cond-scrape-success",
              "operator": {
                "type": "string",
                "operation": "equals"
              },
              "leftValue": "={{ String($json.success) }}",
              "rightValue": "true"
            }
          ]
        },
        "options": {}
      },
      "id": "node-wf01-04",
      "name": "IF - Scrape Success",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        912,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "// Flatten leads array — handle both direct and body-wrapped response\nconst data = $json.body || $json;\nconst source = data.source || $json.source;\nconst leads = data.leads || data.results || [];\nreturn leads.map(lead => ({\n  json: { ...lead, source }\n}));"
      },
      "id": "node-wf01-05",
      "name": "Expand Leads",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        192
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT COUNT(*) AS cnt FROM leads WHERE source = '{{ $json.source }}' AND external_id = '{{ $json.external_id }}'",
        "options": {}
      },
      "id": "node-wf01-06",
      "name": "Postgres - Check Duplicate",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        1344,
        192
      ],
      "credentials": {
        "postgres": {
          "id": "6BIVqwzdoEMhGo8H",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-is-new",
              "leftValue": "={{ Number($json.cnt) }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-wf01-07",
      "name": "IF - Is New Lead",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1568,
        192
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO leads (\n  external_id, source, url, title, description,\n  budget_raw, tech_stack, status\n) VALUES (\n  '{{ $json.external_id }}',\n  '{{ $json.source }}',\n  '{{ $json.url }}',\n  '{{ $json.title }}',\n  '{{ $json.description }}',\n  '{{ $json.budget_raw }}',\n  ARRAY[{{ $json.tech_stack ? $json.tech_stack.map(t => `'${t}'`).join(',') : '' }}]::TEXT[],\n  'new'\n)\nON CONFLICT (source, external_id)\nWHERE external_id IS NOT NULL\nDO NOTHING",
        "options": {}
      },
      "id": "node-wf01-08",
      "name": "Postgres - Insert Lead",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        1792,
        64
      ],
      "credentials": {
        "postgres": {
          "id": "6BIVqwzdoEMhGo8H",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// INSERT only returns { success: true } — rebuild scoring input from Expand Leads\nconst lead = $('Expand Leads').item.json;\nreturn [{\n  json: {\n    source: lead.source,\n    external_id: lead.external_id,\n    title: lead.title,\n    description: lead.description,\n    budget_raw: lead.budget_raw,\n    tech_stack: lead.tech_stack\n  }\n}];"
      },
      "id": "node-wf01-08d",
      "name": "Code - Prepare Scoring Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2092,
        64
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, external_id, source, title, description, budget_raw, tech_stack\nFROM leads\nWHERE source = '{{ $json.source }}'\nAND external_id = '{{ $json.external_id }}'\nLIMIT 1",
        "options": {}
      },
      "id": "node-wf01-08e",
      "name": "Postgres - Get Lead ID",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        2392,
        64
      ],
      "credentials": {
        "postgres": {
          "id": "6BIVqwzdoEMhGo8H",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://agency-ollama-scorer:3002/score",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "lead_id",
              "value": "={{ $json.id }}"
            },
            {
              "name": "title",
              "value": "={{ $json.title }}"
            },
            {
              "name": "description",
              "value": "={{ $json.description }}"
            },
            {
              "name": "budget_raw",
              "value": "={{ $json.budget_raw }}"
            },
            {
              "name": "tech_stack",
              "value": "={{ $json.tech_stack }}"
            }
          ]
        },
        "options": {
          "timeout": 35000
        }
      },
      "id": "node-wf01-09",
      "name": "HTTP - Score Lead",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        2616,
        64
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE leads SET\n  status = 'pending_decision',\n  budget_estimate = '{{ $json.budget_estimate }}',\n  risk_score = {{ $json.risk_score }},\n  fit_score = {{ $json.fit_score }},\n  expected_profit_score = {{ $json.expected_profit_score }},\n  recommended_action = '{{ $json.recommended_action }}',\n  reason_summary = '{{ $json.reason_summary }}',\n  ollama_model = '{{ $json.ollama_model }}',\n  scored_at = NOW(),\n  status_updated_at = NOW()\nWHERE id = {{ $json.lead_id }}\nRETURNING id",
        "options": {}
      },
      "id": "node-wf01-10",
      "name": "Postgres - Update Score",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        2840,
        64
      ],
      "credentials": {
        "postgres": {
          "id": "6BIVqwzdoEMhGo8H",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "operation": "rpush",
        "key": "queue:notify",
        "value": "={{ $json.id }}"
      },
      "id": "node-wf01-11",
      "name": "Redis - Push Notify Queue",
      "type": "n8n-nodes-base.redis",
      "typeVersion": 1,
      "position": [
        3064,
        64
      ],
      "credentials": {
        "redis": {
          "id": "AgencyRedis001",
          "name": "Agency Redis"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO agent_logs (agent_name, action, entity_type, entity_id, status, output_summary)\nVALUES ('scraper', 'scrape_success', 'lead', {{ $json.id }}, 'success', 'New lead inserted: {{ $json.title }}')",
        "options": {}
      },
      "id": "node-wf01-08b",
      "name": "Postgres - Log Insert Success",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        3288,
        64
      ],
      "credentials": {
        "postgres": {
          "id": "6BIVqwzdoEMhGo8H",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {},
      "id": "node-wf01-skip",
      "name": "NoOp - Skip Duplicate",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [
        1792,
        304
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO agent_logs (agent_name, action, entity_type, status, error_message, input_summary)\nVALUES ('scraper', 'scrape_failed', 'lead', 'failed', '{{ $json.error || \"Scraper returned success=false\" }}', 'source={{ $json.source }}')",
        "options": {}
      },
      "id": "node-wf01-fail",
      "name": "Postgres - Log Scrape Failed",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        1120,
        432
      ],
      "credentials": {
        "postgres": {
          "id": "6BIVqwzdoEMhGo8H",
          "name": "Postgres account"
        }
      }
    }
  ],
  "connections": {
