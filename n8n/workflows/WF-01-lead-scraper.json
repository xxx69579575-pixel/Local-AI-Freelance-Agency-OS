            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "HTTP - Scrape Source": {
      "main": [
        [
          {
            "node": "IF - Scrape Success",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "IF - Scrape Success": {
      "main": [
        [
          {
