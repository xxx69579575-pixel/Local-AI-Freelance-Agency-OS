      "id": "node-wf03-01",
      "name": "Webhook - Telegram Decision",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300],
      "webhookId": "webhook-telegram-decision"
    },
    {
      "parameters": {
        "jsCode": "// Parse Telegram callback_query or simplified internal format\n// Expected body shapes:\n//   Native Telegram: { callback_query: { data: 'action:quote:42', from: { id: 123 }, message: { message_id: 99 } } }\n//   Internal:        { action: 'quote', lead_id: 42, chat_id: 123, message_id: 99 }\n\nconst body = $json.body || $json;\nlet action, lead_id, chat_id, message_id;\n\nif (body.callback_query) {\n  const data = body.callback_query.data || '';\n  const parts = data.split(':');\n  action = parts[1];\n  lead_id = parseInt(parts[2], 10);\n  chat_id = body.callback_query.from.id;\n  message_id = body.callback_query.message?.message_id;\n} else {\n  action = body.action;\n  lead_id = parseInt(body.lead_id, 10);\n  chat_id = body.chat_id;\n  message_id = body.message_id;\n}\n\nconst validActions = ['quote', 'reject', 'later'];\nif (!validActions.includes(action)) {\n  throw new Error(`Invalid action: ${action}. Must be one of: ${validActions.join(', ')}`);\n}\nif (!lead_id || isNaN(lead_id)) {\n  throw new Error(`Invalid lead_id: ${lead_id}`);\n}\n\nreturn [{ json: { action, lead_id, chat_id, message_id } }];"
      },
      "id": "node-wf03-02",
      "name": "Code - Parse Decision",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "mode": "rules",
        "rules": {
          "values": [
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
                "conditions": [
                  {
                    "id": "cond-quote",
                    "leftValue": "={{ $json.action }}",
                    "rightValue": "quote",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "quote"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
                "conditions": [
                  {
                    "id": "cond-reject",
                    "leftValue": "={{ $json.action }}",
                    "rightValue": "reject",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "reject"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
                "conditions": [
                  {
                    "id": "cond-later",
                    "leftValue": "={{ $json.action }}",
                    "rightValue": "later",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "later"
            }
          ]
        },
        "options": {}
      },
      "id": "node-wf03-03",
      "name": "Switch - Action",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [680, 300]
