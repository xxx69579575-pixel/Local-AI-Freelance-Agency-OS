            { "name": "parse_mode", "value": "Markdown" },
            {
              "name": "reply_markup",
              "value": "={\"inline_keyboard\":[[{\"text\":\"✅ 確認送出\",\"callback_data\":\"approve:quote:{{ $node['Postgres - Insert Quotation Draft'].json.id }}\"},{\"text\":\"✏️ 手動修改\",\"callback_data\":\"edit:quote:{{ $node['Postgres - Insert Quotation Draft'].json.id }}\"}]]}"
            }
